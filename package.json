{
  "name": "comms-app",
  "version": "1.1.1",
  "private": true,
  "productName": "Comms Hub",
  "author": "Gary Yang",
  "description": "Desktop message aggregator for web-based communication apps.",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZevosSky/personal-comms-hub.git"
  },
  "homepage": "https://github.com/ZevosSky/personal-comms-hub",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron . --dev\"",
    "build": "vite build --base ./",
    "smoke": "npm run build && node scripts/smoke-check.mjs",
    "start": "electron .",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && electron-builder --win nsis --x64 --publish never",
    "dist:linux": "npm run build && electron-builder --linux AppImage --x64 --publish never"
  },
  "build": {
    "appId": "com.garyyang.commshub",
    "productName": "Comms Hub",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Network",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createStartMenuShortcut": true,
      "createDesktopShortcut": "always",
      "uninstallDisplayName": "Comms Hub",
      "shortcutName": "Comms Hub",
      "runAfterFinish": false
    }
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "electron": "41.2.0",
    "electron-builder": "26.8.1",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
